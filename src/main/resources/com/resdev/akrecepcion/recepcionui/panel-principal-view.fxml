<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="app-root" stylesheets="@recepcion.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.resdev.akrecepcion.recepcionui.PanelPrincipalController">

    <left>
        <VBox spacing="14.0" styleClass="sidebar">
            <padding>
                <Insets bottom="18.0" left="14.0" right="14.0" top="18.0" />
            </padding>

            <VBox spacing="4.0">
                <Label styleClass="brand-title" text="Centro Médico" />
                <Label styleClass="brand-subtitle" text="Portal de recepción" />
            </VBox>

            <Separator />

            <VBox fx:id="navContainer" spacing="6.0">
                <Button onAction="#onNavClick" styleClass="nav-button" text="Menu Principal" userData="dashboard" />
                <Button onAction="#onNavClick" styleClass="nav-button" text="Nuevo Paciente" userData="nuevo-paciente" />
                <Button onAction="#onNavClick" styleClass="nav-button" text="Pacientes" userData="paciente-recurrente" />
                <Button onAction="#onNavClick" styleClass="nav-button" text="Búsqueda de Pacientes" userData="busqueda-pacientes" />
                <Button onAction="#onNavClick" styleClass="nav-button" text="Agendar" userData="agendar" />
                <Button onAction="#onNavClick" styleClass="nav-button" text="Reportes" userData="reportes" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Button styleClass="danger-button" text="Ingreso de emergencia" />

            <Separator />

            <VBox spacing="6.0">
                <Button onAction="#onNavClick" styleClass="nav-button-tone-secondary" text="Configuración" userData="configuracion" />
                <Button onAction="#onNavClick" styleClass="nav-button-tone-secondary" text="Ayuda" userData="ayuda" />
            </VBox>
        </VBox>
    </left>

    <top>
        <HBox spacing="10.0" styleClass="topbar">
            <padding>
                <Insets bottom="14.0" left="18.0" right="18.0" top="14.0" />
            </padding>

            <Label styleClass="app-title" text="Hospitalito Atitlan" />

            <Region HBox.hgrow="ALWAYS" />

            <TextField promptText="Buscar paciente" styleClass="search-field" />
            <Button styleClass="ghost-button" text="Notificaciones" />
            <Button onAction="#onPerfil" styleClass="ghost-button" text="Perfil" />
            <Button onAction="#onCerrarSesion" text="Cerrar sesión">
                <styleClass>
                    <String fx:value="ghost-button-tone-logout" />
                </styleClass>
            </Button>
        </HBox>
    </top>

    <center>
        <StackPane fx:id="centerHost" styleClass="content-host">
            <VBox fx:id="dashboardView" spacing="18.0" styleClass="content">
                <padding>
                    <Insets bottom="22.0" left="18.0" right="18.0" top="22.0" />
                </padding>

                <VBox spacing="6.0">
                    <Label fx:id="lblSaludo" styleClass="h1" text="Bienvenido de nuevo" />
                    <Label fx:id="lblResumen" styleClass="muted" text="Resumen" />
                </VBox>

                <HBox spacing="14.0">
                    <VBox spacing="8.0" styleClass="card">
                        <Label styleClass="card-title" text="Nuevo paciente" />
                        <Label styleClass="muted" text="Inicia un registro para un nuevo ingreso. Captura datos y crea el expediente." wrapText="true" />
                        <Button onAction="#onIniciarRegistro" styleClass="link-button" text="Iniciar registro" />
                    </VBox>
                    <VBox spacing="8.0" styleClass="card">
                        <Label styleClass="card-title" text="Paciente recurrente" />
                        <Label styleClass="muted" text="Búsqueda rápida para pacientes existentes y actualización del motivo de visita." wrapText="true" />
                        <Button onAction="#onRecuperarPerfil" styleClass="link-button" text="Recuperar perfil" />
                    </VBox>
                </HBox>

                        <HBox spacing="14.0">
                    <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <Label styleClass="section-title" text="Actividad de hoy" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button styleClass="ghost-link" text="Ver todos los registros" />
                        </HBox>

                        <HBox spacing="10.0">
                            <VBox spacing="3.0" styleClass="stat">
                                <Label styleClass="stat-value" text="24" />
                                <Label styleClass="stat-label" text="COMPLETADOS" />
                            </VBox>
                            <VBox spacing="3.0" styleClass="stat">
                                <Label styleClass="stat-value" text="8" />
                                <Label styleClass="stat-label" text="EN PROGRESO" />
                            </VBox>
                            <VBox spacing="3.0" styleClass="stat">
                                <Label styleClass="stat-value" text="12" />
                                <Label styleClass="stat-label" text="PROGRAMADOS" />
                            </VBox>
                        </HBox>

                        <VBox styleClass="ps-table-pp-activity-table">
                            <HBox styleClass="ps-table-header">
                                <Label styleClass="ps-th" text="PACIENTE" HBox.hgrow="ALWAYS" />
                                <Label prefWidth="130.0" styleClass="ps-th" text="TIPO" />
                                <Label prefWidth="130.0" styleClass="ps-th" text="ESTADO" />
                                <Label prefWidth="90.0" styleClass="ps-th" text="HORA" />
                                <Label prefWidth="120.0" styleClass="ps-th" text="ACCIONES" />
                            </HBox>

                            <Separator styleClass="ps-table-sep" />

                            <VBox fx:id="actividadRowsContainer" styleClass="ps-table-rows" />
                        </VBox>
                    </VBox>

                    <VBox prefWidth="290.0" spacing="14.0">
                        <VBox spacing="10.0" styleClass="card">
                            <Label styleClass="card-title" text="Herramientas rápidas" />
                            <Button styleClass="tool-button" text="Agenda semanal" />
                            <Button styleClass="tool-button" text="Agenda diaria" />
                            <Button styleClass="tool-button" text="Ultimo paciente" />
                        </VBox>

                        <VBox fx:id="systemHealthCard" spacing="10.0">
                            <styleClass>
                                <String fx:value="card" />
                                <String fx:value="teal-card" />
                            </styleClass>
                            <Label text="Salud del sistema">
                                <styleClass>
                                <String fx:value="card-title" />
                                <String fx:value="inverted" />
                                </styleClass>
                            </Label>
                            <Label fx:id="lblSystemHealthStatus" text="Red óptima">
                                <styleClass>
                                    <String fx:value="h2" />
                                    <String fx:value="inverted" />
                                </styleClass>
                            </Label>
                            <Label fx:id="lblSystemHealthSync" text="Sincronización segura activa">
                                <styleClass>
                                    <String fx:value="muted" />
                                    <String fx:value="inverted" />
                                </styleClass>
                            </Label>
                        </VBox>
                    </VBox>
                </HBox>
            </VBox>

            <StackPane fx:id="navViewHost" managed="false" visible="false" />
        </StackPane>
    </center>

</BorderPane>
