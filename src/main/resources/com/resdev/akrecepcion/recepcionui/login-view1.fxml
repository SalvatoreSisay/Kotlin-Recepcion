<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.effect.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600" prefWidth="900" styleClass="login-root" stylesheets="@login.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.resdev.akrecepcion.recepcionui.LoginController">

    <!-- Background -->
    <ImageView fitHeight="900.0" fitWidth="1400.0" preserveRatio="true" styleClass="bg-image">
        <effect>
            <GaussianBlur radius="22.0" />
        </effect>
        <Image url="@FondoLogin.png" />
    </ImageView>
    <Region prefHeight="0.0" prefWidth="0.0" styleClass="bg-scrim" />

    <!-- Top brand -->
    <BorderPane maxWidth="1600.0" pickOnBounds="false" prefHeight="46.0" prefWidth="1400.0">
        <padding>
            <Insets bottom="18.0" left="12.0" right="12.0" top="8.0" />
        </padding>
        <left>
            <HBox spacing="10.0" styleClass="brand-row">
                <StackPane styleClass="brand-mark">
                    <Label styleClass="brand-plus" text="+" />
                </StackPane>
                <Label styleClass="brand-name" text="Hospitalito Atitlan" />
            </HBox>
        </left>

        <right>
            <Label  prefHeight="13.0" prefWidth="310.0" styleClass="brand-secure" text="Asociación K'aslímaal" />
        </right>
    </BorderPane>

    <StackPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <Pane styleClass="bg-scrim" />

        <VBox alignment="CENTER" maxWidth="520">
            <VBox alignment="CENTER" maxWidth="420" spacing="18" styleClass="login-card">

                <StackPane styleClass="card-icon">
                    <Label styleClass="card-icon-text" text="ID" />
                </StackPane>

                <Label styleClass="card-title" text="Portal de Registro" />
                <Label styleClass="card-subtitle" text="Ingresa tus credenciales para acceder al sistema." textAlignment="CENTER" wrapText="true" />

                <VBox maxWidth="Infinity" spacing="5">
                    <Label styleClass="field-label" text="ID DE EMPLEADO / USUARIO" />

                    <HBox fx:id="usuarioWrap" alignment="CENTER_LEFT" spacing="8" styleClass="field-wrap">
                        <StackPane styleClass="field-icon">
                            <Label styleClass="field-icon-text" text="ID" />
                        </StackPane>

                        <TextField fx:id="txtUsuario" promptText="ej. CS-98421" styleClass="field" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>

                <VBox maxWidth="Infinity" spacing="5">
                    <Label styleClass="field-label" text="CONTRASEÑA" />

                    <HBox fx:id="contrasenaWrap" alignment="CENTER_LEFT" spacing="8" styleClass="field-wrap">
                        <StackPane styleClass="field-icon">
                            <Label styleClass="field-icon-text" text="*" />
                        </StackPane>

                        <PasswordField fx:id="txtContrasena" promptText="********" styleClass="field" HBox.hgrow="ALWAYS" />

                        <TextField fx:id="txtContrasenaVisible" promptText="********" styleClass="field-password-visible" HBox.hgrow="ALWAYS" />

                        <Button onAction="#onTogglePassword" styleClass="field-eye" text="Ver" />
                    </HBox>
                </VBox>

                <HBox alignment="CENTER_LEFT" maxWidth="Infinity" spacing="10">
                    <CheckBox styleClass="checkbox" text="Recordarme" />

                    <Pane HBox.hgrow="ALWAYS" />

                    <Button styleClass="link" text="¿Olvidaste tu contraseña?" />
                </HBox>

                <Button maxWidth="Infinity" onAction="#onLoginClick" styleClass="primary" text="Ingresar al portal →" />

                <Label alignment="CENTER" maxWidth="Infinity" styleClass="pill" text="AUTENTICACIÓN MULTIFACTOR ACTIVA" />

                <HBox alignment="CENTER" spacing="5">
                    <Label styleClass="foot-muted" text="¿No tienes una cuenta?" />
                    <Button styleClass="link" text="Crear cuenta" />
                </HBox>
            </VBox>
        </VBox>

        <!-- Bottom links -->
        <BorderPane maxWidth="1600.0" pickOnBounds="false">
            <padding>
                <Insets bottom="18.0" left="22.0" right="22.0" top="18.0" />
            </padding>
            <bottom>
                <HBox alignment="CENTER_LEFT" spacing="14.0">
                    <Label styleClass="bottom-link" text="POLÍTICA DE PRIVACIDAD" />
                    <Label styleClass="bottom-link" text="TÉRMINOS DEL SERVICIO" />
                    <Label styleClass="bottom-link" text="CONTACTAR SOPORTE" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="bottom-muted" text="© 2026 ISD Informatica y Servicion de Desarrollo" />
                </HBox>
            </bottom>
        </BorderPane>

        <StackPane fx:id="popupOverlay" managed="false" styleClass="popup-overlay" visible="false" StackPane.alignment="CENTER">

            <VBox fx:id="popupCard" alignment="CENTER" maxHeight="360" maxWidth="260" prefWidth="260" spacing="8" styleClass="popup-card">

                <Label styleClass="popup-title" text="Error de autenticación" />
                <Label fx:id="lblPopupMensaje" styleClass="popup-message" text="Credenciales incorrectas" textAlignment="CENTER" wrapText="true" />
                <Button fx:id="btnPopupAceptar" onAction="#onPopupAceptar" styleClass="popup-ok" text="Aceptar" />
            </VBox>

        </StackPane>
    </StackPane>

</AnchorPane>
